import seaborn as sns
from sklearn.model_selection import train_test_split

# 1. 데이터 로드 (이 줄이 반드시 있어야 'tips'를 인식합니다)
tips = sns.load_dataset('tips')

# 2. 'day' 컬럼의 비율을 유지하며 전체의 20%를 추출
stratified_sample, _ = train_test_split(tips, test_size=0.2, stratify=tips['day'], random_state=42)

print("--- 층화추출 결과 (요일별 비율) ---")
print(stratified_sample['day'].value_counts(normalize=True))