import os
import math
import matplotlib.pyplot as plt
from PIL import Image

IMG_FOLDER = "rocket_images"

def step3_visualize_grid(max_images=50, cols=5):
    """
    [단계 3: 다운로드된 이미지 50개 그리드 시각화]
    한 열(행)당 5개씩 배치하여 전체 이미지를 출력합니다.
    """
    print(f"\n=== [단계 3] 다운로드된 이미지 시각화 시작 (최대 {max_images}개) ===")
    
    if not os.path.exists(IMG_FOLDER):
        print(f"[-] 오류: '{IMG_FOLDER}' 폴더를 찾을 수 없습니다.")
        return
        
    # 확장자 필터링 및 파일 목록 불러오기
    valid_extensions = ('.jpg', '.jpeg', '.png')
    image_files = [f for f in os.listdir(IMG_FOLDER) if f.lower().endswith(valid_extensions)]
    
    # 최대 50개까지만 자르기
    image_files = image_files[:max_images]
    num_images = len(image_files)
    
    if num_images == 0:
        print("[-] 오류: 시각화할 이미지 파일이 없습니다.")
        return
        
    print(f"[+] 총 {num_images}개의 이미지를 {cols}열로 배치하여 시각화합니다.")
    
    # 1. 행(Row) 개수 계산: 전체 이미지 수를 5로 나누고 올림 처리
    rows = math.ceil(num_images / cols)
    
    # 2. 도화지 및 격자(Axes) 생성
    # 가로 사이즈는 15로 고정하여 동일한 넓이를 확보하고, 세로는 행 개수에 비례하여 늘림
    fig, axes = plt.subplots(nrows=rows, ncols=cols, figsize=(15, 3 * rows))
    
    # 다루기 쉽도록 2차원 배열의 axes를 1차원 리스트로 평탄화(flatten)
    axes = axes.flatten()
    
    # 3. 반복문을 통한 이미지 렌더링
    for i, file_name in enumerate(image_files):
        img_path = os.path.join(IMG_FOLDER, file_name)
        
        try:
            img = Image.open(img_path)
            
            # 격자 안에 이미지 렌더링 (matplotlib이 자동으로 해당 칸의 너비에 맞춰 비율 축소/확대)
            axes[i].imshow(img)
            
            # 제목을 너무 길지 않게 파일명으로 간략히 표시
            axes[i].set_title(file_name, fontsize=9)
            
            # X, Y축 눈금선과 테두리 숨기기 (깔끔한 갤러리 형태)
            axes[i].axis('off')
            
        except Exception as e:
            print(f"[!] {file_name} 로드 오류: {e}")
            axes[i].axis('off')
            
    # 4. 남는 빈 칸 숨기기 (예: 이미지가 47개면 남은 3칸의 테두리를 지움)
    for j in range(num_images, len(axes)):
        axes[j].axis('off')
        
    # 여백 자동 조절 및 최종 출력
    plt.tight_layout()
    plt.show()

# 메인 실행부
if __name__ == "__main__":
    # 한 줄에 5개씩, 최대 50개 이미지 시각화 함수 호출
    step3_visualize_grid(max_images=50, cols=5)